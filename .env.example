# ===== Server (fetcher/api) =====
TIMEFRAMES=1m,5m,15m,1h,4h,1d
FETCH_INTERVAL_SECONDS=300
OHLCV_HISTORY_LIMIT=1000
CONCURRENCY_LIMIT=10
BYBIT_BASE_URL=https://api.bybit.com
DB_PATH=/app/data/cmma.db

# ===== Client notifier =====
# Required
DISCORD_WEBHOOK_URL=

# Docker compose service-to-service URL
CMMA_VOLATILITY_API_URL=http://nginx/volatility
CMMA_VOLUME_API_URL=http://nginx/volume

TIMEFRAME=4h
THRESHOLD=5.0
OFFSET=1
DIRECTION=up
CMMA_VOLATILITY_API_SORT=volatility_desc
CMMA_VOLATILITY_API_LIMIT=100
MAX_NOTIFICATIONS=20
RENOTIFY_BUFFER_MINUTES=240
CHECK_INTERVAL_SECONDS=300
VOLUME_THRESHOLD=1000000.0
VOLUME_TIMEFRAME=1h
VOLUME_PERIOD=24h
CMMA_VOLUME_API_SORT=turnover_desc
CMMA_VOLUME_API_LIMIT=100
LOG_MAX_SIZE_MB=10
